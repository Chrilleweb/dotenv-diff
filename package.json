{
  "name": "dotenv-diff-root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "coverage": "turbo coverage",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "changeset": "changeset",
    "release:notes": "node scripts/update-root-changelog.mjs",
    "changelog:root": "node scripts/update-root-changelog.mjs --write",
    "version": "pnpm changelog:root && changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "turbo": "^2.8.16",
    "@changesets/cli": "^2.30.0"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.30.3"
}
