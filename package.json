{
  "name": "dotenv-diff-root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "coverage": "turbo coverage",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "release:npm": "pnpm --filter dotenv-diff release"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "turbo": "^2.8.16"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "sh -c 'turbo lint -- --fix'",
      "sh -c 'turbo format'"
    ],
    "*.{json,md,yml}": [
      "sh -c 'turbo format'"
    ]
  },
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "@changesets/cli": "^2.30.0"
  }
}
